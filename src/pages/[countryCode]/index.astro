---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getRegionParams } from "../../lib/params/region-params";
import heroImage from "../../assets/hero.png";

export const getStaticPaths = getRegionParams;

const { countryCode } = Astro.params;
---

<Layout
  description="E-commerce starter template built with Astro and Medusa for maximum performance. Browse our collection of products."
  image={heroImage.src}
>
  <section class="jumia-hero">
    <div class="jumia-container jumia-max-w-7xl jumia-px-4 jumia-mx-auto">
      <div class="jumia-grid jumia-grid-2 jumia-gap-12 jumia-items-center">
        <div class="jumia-hero-content">
          <h1 class="jumia-hero-title">
            Astro + Medusa <span class="jumia-text-orange">e-commerce</span> starter template
          </h1>
          <p class="jumia-hero-subtitle">
            This template is a good way to start building your e-commerce store with
            maximum performance in mind.
          </p>
          <div class="jumia-flex jumia-gap-4 jumia-mt-6">
            <a
              href="https://github.com/Bystrol/astro-medusa-starter"
              target="_blank"
              class="jumia-hero-btn jumia-hero-btn-white"
            >
              Open Github
            </a>
            <a
              href={`/${countryCode}/store`}
              class="jumia-hero-btn jumia-hero-btn-orange"
            >
              Browse products
            </a>
          </div>
        </div>

        <div class="jumia-relative jumia-hidden jumia-h-full jumia-min-h-[36rem] jumia-md:flex jumia-flex-1 jumia-items-center jumia-justify-end">
          <Image
            src={heroImage}
            width={800}
            height={900}
            alt="Featured product"
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 50vw, 40vw"
            format="webp"
            quality={80}
            class="jumia-pointer-events-none jumia-absolute jumia-right-[-58%] jumia-top-1/2 jumia-z-10 jumia-h-auto jumia-max-h-none jumia-w-[66rem] jumia-max-w-none jumia--translate-y-1/2 jumia-object-contain jumia-lg:right-[-64%] jumia-lg:w-[82rem] jumia-xl:right-[-62%] jumia-xl:w-[98rem]"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
