---
import Layout from "@layouts/Layout.astro";
import { retrieveProduct } from "@lib/data/products";
import { getRegion } from "@lib/data/regions";
import { getProductParams } from "@lib/params/product-params";
import { getProductPrice } from "@lib/utils/get-product-price";
import ImageCarouselWrapper from "@modules/products/components/product-details/image-carousel/ImageCarouselWrapper.astro";
import { ProductActions } from "@modules/products/components/product-details/ProductActions";
import ProductAttributes from "@modules/products/components/product-details/ProductAttributes.astro";

export const getStaticPaths = getProductParams;

const { countryCode, productId } = Astro.params;

if (!countryCode || !productId) {
  return Astro.redirect("/not-found");
}

const region = await getRegion(countryCode);

if (!region) {
  return Astro.redirect("/not-found");
}

let product: Awaited<ReturnType<typeof retrieveProduct>> | undefined;
let error: Error | undefined;

try {
  product = await retrieveProduct(productId, region.id);
} catch (e) {
  error = e instanceof Error ? e : new Error("Unknown error");
  console.error(error);
}

const {
  title,
  description,
  images,
  options,
  variants,
  material,
  origin_country,
  type,
  weight,
  length,
  width,
  height,
} = product ?? {};

const { cheapestPrice } = getProductPrice({
  productVariants: variants ?? [],
});
---

<Layout
  title={title}
  description={description ?? `Shop ${title} at the best price.`}
  image={images?.[0]?.url}
  type="product"
>
  {error && <p class="jumia-alert jumia-alert-error">{error.message}</p>}
  {
    product && (
      <div class="jumia-section jumia-section-padding">
        <div class="jumia-container jumia-max-w-7xl jumia-px-4 jumia-mx-auto">
          <div class="jumia-grid jumia-grid-1 jumia-gap-8 jumia-py-6 jumia-md:px-12 jumia-lg:jumia-grid-2 jumia-lg:jumia-gap-20 jumia-lg:px-16">
            <ImageCarouselWrapper
              images={images ?? []}
              alt={title ?? "Product image"}
            />

            <div class="jumia-flex jumia-flex-col jumia-gap-8">
              <div class="jumia-flex jumia-flex-col jumia-gap-4">
                <h1 class="jumia-text-4xl jumia-font-bold jumia-text-black">{title}</h1>
                <p class="jumia-text-gray jumia-text-base jumia-leading-relaxed">{description}</p>
                {cheapestPrice && (
                  <div class="jumia-flex jumia-items-center jumia-gap-4">
                    <p class="jumia-text-4xl jumia-font-bold jumia-text-black">
                      {cheapestPrice.calculated_price}
                    </p>
                    {cheapestPrice.original_price && (
                      <p class="jumia-text-lg jumia-text-gray jumia-line-through">
                        {cheapestPrice.original_price}
                      </p>
                    )}
                  </div>
                )}
              </div>

              <ProductActions
                options={options ?? []}
                variants={variants ?? []}
                productId={productId}
                regionId={region.id}
                client:visible
              />

              <ProductAttributes
                material={material}
                origin_country={origin_country}
                type={type}
                weight={weight}
                length={length}
                width={width}
                height={height}
              />
            </div>
          </div>
        </div>
      </div>
    )
  }
</Layout>
