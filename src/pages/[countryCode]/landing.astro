---
import Layout from "@layouts/Layout.astro";
import { getRegionParams } from "@lib/params/region-params";

export const getStaticPaths = getRegionParams;

const { countryCode } = Astro.params;

if (!countryCode) {
  return Astro.redirect("/not-found");
}
---

<Layout title="Premium Wireless Earbuds - Nigeria" description="High-quality wireless earbuds with fast charging, long battery life, and Nigerian support. Pay on delivery available.">
  <main class="jumia-max-w-7xl jumia-mx-auto jumia-px-4">
    
    {/* Hero Section */}
    <section class="jumia-relative jumia-w-full jumia-min-h-screen jumia-flex jumia-items-center jumia-justify-center jumia-bg-cover jumia-bg-center jumia-bg-no-repeat" style="background-image: url('https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=1920&h=1080&fit=crop');">
      <div class="jumia-absolute jumia-inset-0 jumia-bg-black jumia-bg-opacity-50"></div>
      
      <div class="jumia-relative jumia-z-10 jumia-text-center jumia-px-4 jumia-py-16">
        <h1 class="jumia-text-3xl jumia-md:text-5xl jumia-font-bold jumia-text-white jumia-mb-6 jumia-leading-tight">
          Premium Wireless Earbuds
        </h1>
        
        <p class="jumia-text-white jumia-text-lg jumia-md:text-xl jumia-mb-8">
          Compatible with iPhone, Galaxy, Pixel & All Devices
        </p>
        
        <div class="jumia-flex jumia-flex-col jumia-items-center jumia-mb-8">
          <div class="jumia-flex jumia-items-center jumia-gap-4 jumia-text-4xl jumia-font-bold jumia-text-white">
            <span class="jumia-text-orange-500">₦27,900</span>
            <span class="jumia-text-gray-300 jumia-text-2xl jumia-line-through">₦35,900</span>
          </div>
          <p class="jumia-text-orange-400 jumia-text-sm jumia-mt-2">Limited time offer - Save ₦8,000</p>
        </div>
        
        <a
          href={`/${countryCode}/cart`}
          class="jumia-inline-block jumia-bg-orange-600 jumia-text-white jumia-text-xl jumia-font-bold jumia-py-4 jumia-px-12 jumia-rounded jumia-hover:bg-orange-700 jumia-transition-all jumia-transform jumia-hover:scale-105 jumia-shadow-lg jumia-w-full jumia-max-w-md"
        >
          Order Now - Pay on Delivery
        </a>
        
        <p class="jumia-text-white jumia-text-sm jumia-mt-4">
          ✅ Free Delivery in Lagos ✅ 1-Year Warranty ✅ 30-Day Return
        </p>
      </div>
    </section>
    
    {/* Product Benefits Section */}
    <section class="jumia-py-16 jumia-bg-white">
      <div class="jumia-max-w-6xl jumia-mx-auto jumia-px-4">
        <h2 class="jumia-text-3xl jumia-font-bold jumia-text-center jumia-mb-12 jumia-text-gray-900">
          Why Choose Our Earbuds?
        </h2>
        
        <div class="jumia-grid jumia-grid-cols-1 jumia-md:grid-cols-2 jumia-lg:grid-cols-3 jumia-gap-8">
          {/* Fast Charging Feature */}
          <div class="jumia-text-center jumia-p-6 jumia-border jumia-border-gray-200 jumia-rounded-lg jumia-transition-all jumia-hover:shadow-lg">
            <div class="jumia-w-16 jumia-h-16 jumia-mx-auto jumia-bg-orange-100 jumia-rounded-full jumia-flex jumia-items-center jumia-justify-center jumia-mb-4">
              <svg class="jumia-w-8 jumia-h-8 jumia-text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="jumia-text-xl jumia-font-bold jumia-text-gray-900 jumia-mb-2">Fast Charging</h3>
            <p class="jumia-text-gray-600">Get 2 hours of playback with just 10 minutes charge</p>
          </div>
          
          {/* Battery Life Feature */}
          <div class="jumia-text-center jumia-p-6 jumia-border jumia-border-gray-200 jumia-rounded-lg jumia-transition-all jumia-hover:shadow-lg">
            <div class="jumia-w-16 jumia-h-16 jumia-mx-auto jumia-bg-orange-100 jumia-rounded-full jumia-flex jumia-items-center jumia-justify-center jumia-mb-4">
              <svg class="jumia-w-8 jumia-h-8 jumia-text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18v-6m0 0V6m0 6h6m-6 0H6"></path>
              </svg>
            </div>
            <h3 class="jumia-text-xl jumia-font-bold jumia-text-gray-900 jumia-mb-2">40 Hours Battery</h3>
            <p class="jumia-text-gray-600">Extended playtime with convenient charging case</p>
          </div>
          
          {/* Noise Cancellation Feature */}
          <div class="jumia-text-center jumia-p-6 jumia-border jumia-border-gray-200 jumia-rounded-lg jumia-transition-all jumia-hover:shadow-lg">
            <div class="jumia-w-16 jumia-h-16 jumia-mx-auto jumia-bg-orange-100 jumia-rounded-full jumia-flex jumia-items-center jumia-justify-center jumia-mb-4">
              <svg class="jumia-w-8 jumia-h-8 jumia-text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path>
              </svg>
            </div>
            <h3 class="jumia-text-xl jumia-font-bold jumia-text-gray-900 jumia-mb-2">Noise Cancellation</h3>
            <p class="jumia-text-gray-600">Clear audio with active noise cancellation</p>
          </div>
          
          {/* Water Resistant Feature */}
          <div class="jumia-text-center jumia-p-6 jumia-border jumia-border-gray-200 jumia-rounded-lg jumia-transition-all jumia-hover:shadow-lg">
            <div class="jumia-w-16 jumia-h-16 jumia-mx-auto jumia-bg-orange-100 jumia-rounded-full jumia-flex jumia-items-center jumia-justify-center jumia-mb-4">
              <svg class="jumia-w-8 jumia-h-8 jumia-text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
              </svg>
            </div>
            <h3 class="jumia-text-xl jumia-font-bold jumia-text-gray-900 jumia-mb-2">IPX5 Water Resistant</h3>
            <p class="jumia-text-gray-600">Sweat and rain resistant for all activities</p>
          </div>
          
          {/* Bluetooth Feature */}
          <div class="jumia-text-center jumia-p-6 jumia-border jumia-border-gray-200 jumia-rounded-lg jumia-transition-all jumia-hover:shadow-lg">
            <div class="jumia-w-16 jumia-h-16 jumia-mx-auto jumia-bg-orange-100 jumia-rounded-full jumia-flex jumia-items-center jumia-justify-center jumia-mb-4">
              <svg class="jumia-w-8 jumia-h-8 jumia-text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
              </svg>
            </div>
            <h3 class="jumia-text-xl jumia-font-bold jumia-text-gray-900 jumia-mb-2">Bluetooth 5.0</h3>
            <p class="jumia-text-gray-600">Stable connection with all your devices</p>
          </div>
          
          {/* Dual Connection Feature */}
          <div class="jumia-text-center jumia-p-6 jumia-border jumia-border-gray-200 jumia-rounded-lg jumia-transition-all jumia-hover:shadow-lg">
            <div class="jumia-w-16 jumia-h-16 jumia-mx-auto jumia-bg-orange-100 jumia-rounded-full jumia-flex jumia-items-center jumia-justify-center jumia-mb-4">
              <svg class="jumia-w-8 jumia-h-8 jumia-text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
              </svg>
            </div>
            <h3 class="jumia-text-xl jumia-font-bold jumia-text-gray-900 jumia-mb-2">Dual Connection</h3>
            <p class="jumia-text-gray-600">Connect to two devices simultaneously</p>
          </div>
        </div>
      </div>
    </section>
    
    {/* Product Usage Section */}
    <section class="jumia-py-16 jumia-bg-gray-50">
      <div class="jumia-max-w-6xl jumia-mx-auto jumia-px-4">
        <h2 class="jumia-text-3xl jumia-font-bold jumia-text-center jumia-mb-12 jumia-text-gray-900">
          Perfect for Every Occasion
        </h2>
        
        <div class="jumia-grid jumia-grid-cols-1 jumia-md:grid-cols-2 jumia-gap-8">
          <div class="jumia-relative jumia-overflow-hidden jumia-rounded-lg jumia-shadow-lg">
            <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=800&h=600&fit=crop" alt="Working at desk" class="jumia-w-full jumia-h-64 jumia-object-cover jumia-transition-transform jumia-hover:scale-105">
            <div class="jumia-absolute jumia-bottom-0 jumia-left-0 jumia-right-0 jumia-bg-gradient-to-t jumia-from-black jumia-to-transparent jumia-p-4">
              <p class="jumia-text-white jumia-font-bold">Work & Productivity</p>
            </div>
          </div>
          
          <div class="jumia-relative jumia-overflow-hidden jumia-rounded-lg jumia-shadow-lg">
            <img src="https://images.unsplash.com/photo-1516280440614-6697288d5d38?w=800&h=600&fit=crop" alt="Person running" class="jumia-w-full jumia-h-64 jumia-object-cover jumia-transition-transform jumia-hover:scale-105">
