          <div class="jumia-relative jumia-overflow-hidden jumia-rounded-lg jumia-shadow-lg">
            <img src="https://images.unsplash.com/photo-1551836022-d5d8b5f20035?w=800&h=600&fit=crop" alt="Traveling" class="jumia-w-full jumia-h-64 jumia-object-cover jumia-transition-transform jumia-hover:scale-105">
            <div class="jumia-absolute jumia-bottom-0 jumia-left-0 jumia-right-0 jumia-bg-gradient-to-t jumia-from-black jumia-to-transparent jumia-p-4">
              <p class="jumia-text-white jumia-font-bold">On The Go</p>
            </div>
          </div>
        </div>
      </div>
