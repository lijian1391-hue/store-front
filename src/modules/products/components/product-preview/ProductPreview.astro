---
import { getProductPrice } from "../../../../lib/utils/get-product-price";
import type { ProductVariant } from "../../../../types/global";
import Thumbnail from "../thumbnail/Thumbnail.astro";
import Price from "./Price.astro";

interface Props {
  id: string;
  variants: ProductVariant[];
  thumbnailUrl?: string;
  imageUrl?: string;
  title: string;
  priority?: boolean;
}

const { id, variants, thumbnailUrl, imageUrl, title, priority } = Astro.props;
const countryCode = Astro.params.countryCode;

const { cheapestPrice } = getProductPrice({
  productVariants: variants,
});
---

<a
  href={`/${countryCode}/store/${id}`}
  class="jumia-product-card jumia-flex jumia-flex-col jumia-h-full jumia-gap-4 jumia-justify-between jumia-group"
>
  <div class="jumia-relative">
    <Thumbnail imageUrl={thumbnailUrl || imageUrl} title={title} priority={priority} />
    {cheapestPrice && cheapestPrice.original_price && cheapestPrice.calculated_price && (
      <span class="jumia-badge jumia-badge-orange jumia-sale-badge">
        Sale
      </span>
    )}
  </div>

  <div class="jumia-p-4">
    <h3 class="jumia-product-title jumia-truncate-2">{title}</h3>
    
    {cheapestPrice && (
      <div class="jumia-flex jumia-items-center jumia-gap-2 jumia-mt-2">
        <Price
          priceType={cheapestPrice.price_type ?? ""}
          originalPrice={cheapestPrice.original_price}
          calculatedPrice={cheapestPrice.calculated_price}
        />
      </div>
    )}
    
    <div class="jumia-flex jumia-items-center jumia-gap-2 jumia-mt-3">
      <span class="jumia-text-xs jumia-text-gray">★★★★★</span>
      <span class="jumia-text-xs jumia-text-gray/60">(128)</span>
    </div>
  </div>
</a>
