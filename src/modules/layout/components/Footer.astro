---
interface Props {
  countryCode: string;
}

const { countryCode } = Astro.props;
const currentYear = new Date().getFullYear();

const shopLinks = [
  { href: `/${countryCode}`, label: "Home" },
  { href: `/${countryCode}/store`, label: "All products" },
  { href: `/${countryCode}/cart`, label: "Cart" },
  { href: `/${countryCode}/checkout`, label: "Checkout" },
];

const companyLinks = [
  { href: `/${countryCode}/privacy`, label: "Privacy" },
  { href: `/${countryCode}/terms`, label: "Terms" },
  {
    href: "https://github.com/Bystrol/astro-medusa-starter",
    label: "GitHub",
    external: true,
  },
];
---

<footer class="jumia-footer">
  <div class="jumia-container jumia-max-w-7xl jumia-px-4 jumia-mx-auto">
    <div class="jumia-grid jumia-grid-4 jumia-gap-8 jumia-py-12 jumia-border-b jumia-border-white/10">
      <section>
        <p class="jumia-text-xs jumia-font-semibold jumia-uppercase jumia-tracking-[0.28em] jumia-text-gray/55">
          Astro Medusa Starter
        </p>
        <h2 class="jumia-mt-4 jumia-text-3xl jumia-font-semibold jumia-tracking-tight jumia-text-white">
          A storefront that feels ready to ship.
        </h2>
        <p class="jumia-mt-4 jumia-text-sm jumia-leading-6 jumia-text-gray/65">
          Built for fast browsing, clean checkout, and a polished shopping flow
          from first click to confirmed order.
        </p>
      </section>

      <nav aria-label="Footer shop navigation">
        <p class="jumia-text-sm jumia-font-semibold jumia-text-white">Shop</p>
        <ul class="jumia-mt-4 jumia-space-y-3 jumia-text-sm jumia-text-gray/65">
          {
            shopLinks.map((link) => (
              <li>
                <a class="jumia-transition jumia-hover:text-orange" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Footer company navigation">
        <p class="jumia-text-sm jumia-font-semibold jumia-text-white">Company</p>
        <ul class="jumia-mt-4 jumia-space-y-3 jumia-text-sm jumia-text-gray/65">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  class="jumia-transition jumia-hover:text-orange"
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <section>
        <p class="jumia-text-sm jumia-font-semibold jumia-text-white">Customer Care</p>
        <div class="jumia-mt-4 jumia-space-y-4 jumia-text-sm jumia-text-gray/65">
          <p>
            Need help with the starter? Browse the catalog, test the cart, and
            explore the full purchase flow end to end.
          </p>
          <a
            class="jumia-inline-flex jumia-rounded-full jumia-bg-orange jumia-px-5 jumia-py-3 jumia-text-sm jumia-font-medium jumia-text-white jumia-transition jumia-hover:bg-orange-dark"
            href={`/${countryCode}/store`}
          >
            Start shopping
          </a>
        </div>
      </section>
    </div>

    <p class="jumia-text-sm jumia-text-gray/55 jumia-pt-6 jumia-text-center">
      &copy; {currentYear} Astro Medusa Starter. Built by Michał Bystryk.
    </p>
  </div>
</footer>
