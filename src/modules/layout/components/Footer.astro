---
interface Props {
  countryCode: string;
}

const { countryCode } = Astro.props;
const currentYear = new Date().getFullYear();

const shopLinks = [
  { href: `/${countryCode}`, label: "Home" },
  { href: `/${countryCode}/store`, label: "All products" },
  { href: `/${countryCode}/cart`, label: "Cart" },
  { href: `/${countryCode}/checkout`, label: "Checkout" },
];

const companyLinks = [
  { href: `/${countryCode}/privacy`, label: "Privacy" },
  { href: `/${countryCode}/terms`, label: "Terms" },
  {
    href: "https://github.com/Bystrol/astro-medusa-starter",
    label: "GitHub",
    external: true,
  },
];
---

<footer class="border-t border-black/10 bg-stone-50">
  <div class="px-8 py-14 md:px-12 lg:px-16">
    <div
      class="grid gap-10 border-b border-black/10 pb-10 md:grid-cols-2 xl:grid-cols-[1.2fr_0.8fr_0.8fr_1fr]"
    >
      <section class="max-w-md">
        <p
          class="text-xs font-semibold uppercase tracking-[0.28em] text-black/55"
        >
          Astro Medusa Starter
        </p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-black">
          A storefront that feels ready to ship.
        </h2>
        <p class="mt-4 text-sm leading-6 text-black/65">
          Built for fast browsing, clean checkout, and a polished shopping flow
          from first click to confirmed order.
        </p>
      </section>

      <nav aria-label="Footer shop navigation">
        <p class="text-sm font-semibold text-black">Shop</p>
        <ul class="mt-4 space-y-3 text-sm text-black/65">
          {
            shopLinks.map((link) => (
              <li>
                <a class="transition hover:text-black" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Footer company navigation">
        <p class="text-sm font-semibold text-black">Company</p>
        <ul class="mt-4 space-y-3 text-sm text-black/65">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  class="transition hover:text-black"
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <section>
        <p class="text-sm font-semibold text-black">Customer Care</p>
        <div class="mt-4 space-y-4 text-sm text-black/65">
          <p>
            Need help with the starter? Browse the catalog, test the cart, and
            explore the full purchase flow end to end.
          </p>
          <a
            class="inline-flex rounded-full bg-black px-5 py-3 text-sm font-medium text-white transition hover:bg-black/85"
            href={`/${countryCode}/store`}
          >
            Start shopping
          </a>
        </div>
      </section>
    </div>

    <p class="text-sm text-black/55 pt-6">
      &copy; {currentYear} Astro Medusa Starter. Built by Michał Bystryk.
    </p>
  </div>
</footer>
